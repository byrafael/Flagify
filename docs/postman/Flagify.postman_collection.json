{
  "info": {
    "_postman_id": "7d0c1bb4-3b2b-48c9-bf40-flagify-collection-v2",
    "name": "Flagify API",
    "description": "Postman collection for the Flagify admin, runtime, and snapshot API.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://127.0.0.1:8080"
    }
  ],
  "item": [
    {
      "name": "Projects",
      "description": "Project bootstrap and top-level tenancy. Creating a project also creates the default environments: development, staging, and production.",
      "item": [
        {
          "name": "Create Project",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const data = pm.response.json();",
                  "  pm.environment.set('project_id', data.id);",
                  "  pm.environment.set('project_slug', data.slug);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "description": "Create a new project. This is the root container for environments, clients, segments, flags, and keys.",
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{root_key}}", "type": "text" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Example\",\n  \"slug\": \"example\",\n  \"description\": \"Example project\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/projects",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "projects"]
            }
          }
        },
        {
          "name": "List Projects",
          "request": {
            "description": "List visible projects. Root can see all projects; scoped keys only see their bound project.",
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{root_key}}", "type": "text" }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/projects?limit=50&offset=0",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "projects"],
              "query": [
                { "key": "limit", "value": "50" },
                { "key": "offset", "value": "0" }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Keys",
      "description": "API keys control access. Project admin keys manage project resources, project read keys inspect them, and client runtime keys resolve runtime config for one client.",
      "item": [
        {
          "name": "Create Project Admin Key",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const data = pm.response.json();",
                  "  pm.environment.set('project_admin_key_id', data.id);",
                  "  pm.environment.set('project_admin_key', data.secret);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "description": "Create a project admin key for managing flags, environments, segments, clients, overrides, and additional keys inside the project.",
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{root_key}}", "type": "text" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"kind\": \"project_admin\",\n  \"name\": \"Project Admin\",\n  \"project_id\": \"{{project_id}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/keys",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "keys"]
            }
          }
        },
        {
          "name": "Create Project Read Key",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const data = pm.response.json();",
                  "  pm.environment.set('project_read_key_id', data.id);",
                  "  pm.environment.set('project_read_key', data.secret);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "description": "Create a read-only project key. Use this for inspection flows such as listing resources, reading runtime config for any client, and downloading snapshots.",
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{project_admin_key}}", "type": "text" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"kind\": \"project_read\",\n  \"name\": \"Project Read\",\n  \"project_id\": \"{{project_id}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/keys",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "keys"]
            }
          }
        },
        {
          "name": "Create Client Runtime Key",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const data = pm.response.json();",
                  "  pm.environment.set('client_runtime_key_id', data.id);",
                  "  pm.environment.set('client_runtime_key', data.secret);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "description": "Create a runtime key bound to a single client. This key resolves runtime config without exposing broader project access.",
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{project_admin_key}}", "type": "text" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"kind\": \"client_runtime\",\n  \"name\": \"Client Runtime\",\n  \"project_id\": \"{{project_id}}\",\n  \"client_id\": \"{{client_id}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/keys",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "keys"]
            }
          }
        }
      ]
    },
    {
      "name": "Environments",
      "description": "Environments let the same flag behave differently across release contexts such as development, staging, production, or a custom QA environment.",
      "item": [
        {
          "name": "List Environments",
          "request": {
            "description": "List the environments in the project. New projects start with development, staging, and production automatically.",
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{project_admin_key}}", "type": "text" }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/projects/{{project_id}}/environments",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "projects", "{{project_id}}", "environments"]
            }
          }
        },
        {
          "name": "Create QA Environment",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const data = pm.response.json();",
                  "  pm.environment.set('environment_id', data.id);",
                  "  pm.environment.set('environment_key', data.key);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "description": "Create an additional environment. Environments are where environment-specific flag rules and defaults live.",
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{project_admin_key}}", "type": "text" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"key\": \"qa\",\n  \"name\": \"QA\",\n  \"description\": \"Quality assurance environment\",\n  \"sort_order\": 25\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/projects/{{project_id}}/environments",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "projects", "{{project_id}}", "environments"]
            }
          }
        }
      ]
    },
    {
      "name": "Segments",
      "description": "Segments are reusable audiences defined by client attributes. A segment can be referenced by many flag rules to avoid duplicating targeting logic.",
      "item": [
        {
          "name": "Create Premium Segment",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const data = pm.response.json();",
                  "  pm.environment.set('segment_id', data.id);",
                  "  pm.environment.set('segment_key', data.key);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "description": "Create a reusable audience for premium customers. This example matches clients whose metadata.plan is premium.",
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{project_admin_key}}", "type": "text" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"key\": \"premium_users\",\n  \"name\": \"Premium Users\",\n  \"rules\": [\n    {\n      \"attribute\": \"metadata.plan\",\n      \"operator\": \"equals\",\n      \"value\": \"premium\"\n    }\n  ]\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/projects/{{project_id}}/segments",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "projects", "{{project_id}}", "segments"]
            }
          }
        },
        {
          "name": "List Segments",
          "request": {
            "description": "List all active segments available for use in environment-specific flag rules.",
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{project_admin_key}}", "type": "text" }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/projects/{{project_id}}/segments",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "projects", "{{project_id}}", "segments"]
            }
          }
        }
      ]
    },
    {
      "name": "Clients",
      "description": "Clients are the runtime subjects being evaluated. Their metadata is what rule conditions and segments target.",
      "item": [
        {
          "name": "Create Client",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const data = pm.response.json();",
                  "  pm.environment.set('client_id', data.id);",
                  "  pm.environment.set('client_key', data.key);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "description": "Create a client with metadata that can be used for targeting, segment membership, and sticky rollout bucketing.",
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{project_admin_key}}", "type": "text" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"key\": \"acme-inc\",\n  \"name\": \"Acme Inc\",\n  \"metadata\": {\n    \"plan\": \"premium\",\n    \"country\": \"US\",\n    \"app_version\": \"2.4.0\"\n  }\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/projects/{{project_id}}/clients",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "projects", "{{project_id}}", "clients"]
            }
          }
        }
      ]
    },
    {
      "name": "Flags",
      "description": "Flags define the feature itself. Environment-specific config adds ordered rules, rollout percentage, schedules, and served variants or values.",
      "item": [
        {
          "name": "Create Experiment Flag",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const data = pm.response.json();",
                  "  pm.environment.set('flag_id', data.id);",
                  "  pm.environment.set('flag_key', data.key);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "description": "Create a multivariate flag with named variants and payloads. This example models an experiment-style rollout between control and variant_a.",
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{project_admin_key}}", "type": "text" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"key\": \"new_dashboard\",\n  \"name\": \"New Dashboard\",\n  \"description\": \"Roll out the redesigned dashboard\",\n  \"flag_kind\": \"experiment\",\n  \"type\": \"select\",\n  \"default_value\": \"control\",\n  \"options\": [\"control\", \"variant_a\"],\n  \"variants\": [\n    {\n      \"key\": \"control\",\n      \"name\": \"Control\",\n      \"value\": \"control\",\n      \"payload\": { \"theme\": \"legacy\" }\n    },\n    {\n      \"key\": \"variant_a\",\n      \"name\": \"Variant A\",\n      \"value\": \"variant_a\",\n      \"payload\": { \"theme\": \"modern\" }\n    }\n  ],\n  \"default_variant_key\": \"control\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/projects/{{project_id}}/flags",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "projects", "{{project_id}}", "flags"]
            }
          }
        },
        {
          "name": "Configure Production Rules",
          "request": {
            "description": "Set production-specific rules for the flag. This example serves variant_a to 50% of the premium_users segment using sticky bucketing on client key.",
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{project_admin_key}}", "type": "text" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"default_variant_key\": \"control\",\n  \"rules\": [\n    {\n      \"name\": \"Premium rollout\",\n      \"segment_keys\": [\"{{segment_key}}\"],\n      \"conditions\": [],\n      \"percentage\": 50,\n      \"bucketing_key\": \"key\",\n      \"serve\": {\n        \"variant_key\": \"variant_a\"\n      }\n    }\n  ]\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/projects/{{project_id}}/flags/{{flag_id}}/environments/production",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "projects", "{{project_id}}", "flags", "{{flag_id}}", "environments", "production"]
            }
          }
        },
        {
          "name": "List Flags",
          "request": {
            "description": "List project flags and inspect their top-level definition, including kind, variants, prerequisites, and stale status.",
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{project_admin_key}}", "type": "text" }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/projects/{{project_id}}/flags",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "projects", "{{project_id}}", "flags"]
            }
          }
        }
      ]
    },
    {
      "name": "Runtime",
      "description": "Runtime endpoints evaluate flags for a client in a chosen environment. They also expose a snapshot format for local or offline evaluation consumers.",
      "item": [
        {
          "name": "Resolve Runtime Config",
          "request": {
            "description": "Resolve config for the client bound to the runtime key. The environment query parameter selects which environment rules to apply.",
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{client_runtime_key}}", "type": "text" }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/runtime/config?environment=production",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "runtime", "config"],
              "query": [
                { "key": "environment", "value": "production" }
              ]
            }
          }
        },
        {
          "name": "Resolve Project Client Config",
          "request": {
            "description": "Resolve config for any client in a specific environment using a project read or admin key. Useful for debugging targeting decisions.",
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{project_read_key}}", "type": "text" }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/runtime/projects/{{project_id}}/environments/production/clients/{{client_key}}/config",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "runtime", "projects", "{{project_id}}", "environments", "production", "clients", "{{client_key}}", "config"]
            }
          }
        },
        {
          "name": "Fetch Runtime Snapshot",
          "request": {
            "description": "Download an environment snapshot containing flag definitions, segments, and rules. This is the contract intended for local evaluation consumers or future SDKs.",
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{project_read_key}}", "type": "text" }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/runtime/projects/{{project_id}}/environments/production/snapshot",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "runtime", "projects", "{{project_id}}", "environments", "production", "snapshot"]
            }
          }
        }
      ]
    },
    {
      "name": "Events",
      "description": "Evaluation events are the raw exposure trail. They show what value was served, why it was served, which rule matched, and the evaluation context.",
      "item": [
        {
          "name": "List Evaluation Events",
          "request": {
            "description": "List stored evaluation events for debugging and analysis. Filter by environment, flag, or client as needed.",
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{project_read_key}}", "type": "text" }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/projects/{{project_id}}/evaluation-events?environment=production&limit=50&offset=0",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "projects", "{{project_id}}", "evaluation-events"],
              "query": [
                { "key": "environment", "value": "production" },
                { "key": "limit", "value": "50" },
                { "key": "offset", "value": "0" }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Identities",
      "description": "Identity APIs create first-class runtime subjects and manage persisted traits independently from legacy clients.",
      "item": [
        {
          "name": "Create Identity",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{project_admin_key}}", "type": "text" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"kind\": \"user\",\n  \"identifier\": \"user_123\",\n  \"display_name\": \"Primary User\",\n  \"traits\": {\n    \"plan\": \"pro\",\n    \"country\": \"us\"\n  }\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/projects/{{project_id}}/identities",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "projects", "{{project_id}}", "identities"]
            }
          }
        },
        {
          "name": "Evaluate Identity",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{project_read_key}}", "type": "text" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"kind\": \"user\",\n  \"identifier\": \"user_123\",\n  \"transient_traits\": {\n    \"plan\": \"enterprise\"\n  }\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/runtime/projects/{{project_id}}/environments/production/identities/evaluate",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "runtime", "projects", "{{project_id}}", "environments", "production", "identities", "evaluate"]
            }
          }
        }
      ]
    },
    {
      "name": "Operations",
      "description": "Operational APIs cover audit logs, analytics, change requests, import/export, code references, and stale-flag reporting.",
      "item": [
        {
          "name": "List Audit Logs",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{project_read_key}}", "type": "text" }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/projects/{{project_id}}/audit-logs?limit=50&offset=0",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "projects", "{{project_id}}", "audit-logs"],
              "query": [
                { "key": "limit", "value": "50" },
                { "key": "offset", "value": "0" }
              ]
            }
          }
        },
        {
          "name": "Fetch Snapshot With ETag",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{project_read_key}}", "type": "text" },
              { "key": "If-None-Match", "value": "\"{{snapshot_checksum}}\"", "type": "text" }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/runtime/projects/{{project_id}}/environments/production/snapshot",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "runtime", "projects", "{{project_id}}", "environments", "production", "snapshot"]
            }
          }
        }
      ]
    }
  ]
}
